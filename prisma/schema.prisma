generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Sucursal {
  id          Int                 @id @default(autoincrement())
  nombre      String              @db.VarChar(100)
  ubicacion   String?             @db.VarChar(255)
  activo      Boolean             @default(true)
  empleados   EmpleadoSucursal[]
  promociones PromocionSucursal[]
  canjes      CuponAsignado[]
}

model Empleado {
  id         Int                @id @default(autoincrement())
  nombre     String             @db.VarChar(100)
  contrasena String             @db.VarChar(255)
  sucursales EmpleadoSucursal[]
  canjes     CuponAsignado[]
}

model EmpleadoSucursal {
  id_empleado Int
  id_sucursal Int
  rol         String   @db.VarChar(50)
  empleado    Empleado @relation(fields: [id_empleado], references: [id])
  sucursal    Sucursal @relation(fields: [id_sucursal], references: [id])

  @@id([id_empleado, id_sucursal])
}

model Cliente {
  id          Int             @id @default(autoincrement())
  nombre      String          @db.VarChar(100)
  correo      String          @unique @db.VarChar(100)
  telefono    String?         @db.VarChar(15)
  cumpleanios DateTime?
  cupones     CuponAsignado[]

  respuestas  RespuestaUsuario[]
  encuestasCompletadas EncuestaCompletada[]
}

model Encuesta {
  id             Int                 @id @default(autoincrement())
  titulo         String              @db.VarChar(100)
  descripcion    String?             @db.Text
  fecha_creacion DateTime            @default(now())
  
  preguntas      Pregunta[]
  completadas    EncuestaCompletada[]
}

model Pregunta {
  id             Int                 @id @default(autoincrement())
  id_encuesta    Int
  texto_pregunta String              @db.Text
  tipo_pregunta  String              @db.VarChar(50) // 'MULTIPLE', 'ABIERTA', 'RATING'
  orden          Int                 @default(0)

  encuesta       Encuesta            @relation(fields: [id_encuesta], references: [id])
  opciones       OpcionPregunta[]
  respuestas     RespuestaUsuario[]
}

model OpcionPregunta {
  id           Int              @id @default(autoincrement())
  id_pregunta  Int
  texto_opcion String           @db.VarChar(255)

  pregunta     Pregunta         @relation(fields: [id_pregunta], references: [id])
  respuestas   RespuestaUsuario[]
}

model RespuestaUsuario {
  id              Int             @id @default(autoincrement())
  id_pregunta     Int
  id_cliente      Int
  id_opcion       Int?
  respuesta_texto String?         @db.Text

  pregunta        Pregunta        @relation(fields: [id_pregunta], references: [id])
  cliente         Cliente         @relation(fields: [id_cliente], references: [id])
  opcion          OpcionPregunta? @relation(fields: [id_opcion], references: [id])
}

model EncuestaCompletada {
  id               Int            @id @default(autoincrement())
  id_encuesta      Int
  id_cliente       Int
  id_cupon         Int?           @unique // Relación 1:1 con el cupón de premio
  fecha_completado DateTime       @default(now())

  encuesta         Encuesta       @relation(fields: [id_encuesta], references: [id])
  cliente          Cliente        @relation(fields: [id_cliente], references: [id])
  cupon            CuponAsignado? @relation(fields: [id_cupon], references: [id])
}

model Promocion {
  id                Int                 @id @default(autoincrement())
  id_campania_grupo Int?
  nombre            String              @db.VarChar(100)
  tipo_descuento    String              @db.VarChar(50)
  valor             Decimal             @db.Decimal(10, 2)
  fecha_fin         DateTime
  estado            String              @default("ACTIVA") @db.VarChar(50) // ACTIVA, EXPIRADA, DESACTIVADA
  descripcion       String?             @db.Text
  campania          CampaniaGrupo?      @relation(fields: [id_campania_grupo], references: [id])
  sucursales        PromocionSucursal[]
  cupones_emitidos  CuponAsignado[]
}

model PromocionSucursal {
  id_promocion Int
  id_sucursal  Int
  promocion    Promocion @relation(fields: [id_promocion], references: [id])
  sucursal     Sucursal  @relation(fields: [id_sucursal], references: [id])

  @@id([id_promocion, id_sucursal])
}

model CuponAsignado {
  id                Int       @id @default(autoincrement())
  id_cliente        Int
  id_promocion      Int
  id_sucursal_canje Int?
  id_empleado_canje Int?
  codigo_unico      String    @unique @db.VarChar(10)
  estado            String    @default("DISPONIBLE")
  fecha_asignacion  DateTime  @default(now())
  fecha_canje       DateTime?
  ip_registro       String?   @db.VarChar(45)

  cliente   Cliente   @relation(fields: [id_cliente], references: [id])
  promocion Promocion @relation(fields: [id_promocion], references: [id])
  sucursal  Sucursal? @relation(fields: [id_sucursal_canje], references: [id])
  empleado  Empleado? @relation(fields: [id_empleado_canje], references: [id])
  encuestaCompletada EncuestaCompletada?
}

model CampaniaGrupo {
  id          Int         @id @default(autoincrement())
  nombre      String      @db.VarChar(100)
  descripcion String?     @db.Text
  excluyente  Boolean     @default(false)
  promociones Promocion[]
}

model DynamicQR {
  id          String    @id @default(uuid())
  slug        String    @unique
  targetUrl   String
  description String?
  visitCount  Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime? @updatedAt
  visits      QRVisit[]
}

model QRVisit {
  id        Int       @id @default(autoincrement())
  qrId      String
  userAgent String?
  ip        String?
  city      String?
  region    String?
  country   String?
  lat       Float?
  long      Float?
  createdAt DateTime  @default(now())
  dynamicQR DynamicQR @relation(fields: [qrId], references: [id])
}