generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Sucursal {
  id        Int      @id @default(autoincrement())
  nombre    String   @db.VarChar(100)
  ubicacion String?  @db.VarChar(255)
  activo    Boolean  @default(true)

  empleados    EmpleadoSucursal[]
  promociones  PromocionSucursal[]
  canjes       CuponAsignado[]
}

model Empleado {
  id         Int      @id @default(autoincrement())
  nombre     String   @db.VarChar(100)
  contrasena String   @db.VarChar(255) 

  sucursales EmpleadoSucursal[]
  canjes     CuponAsignado[]
}

model EmpleadoSucursal {
  id_empleado Int
  id_sucursal Int
  rol         String   @db.VarChar(50)

  empleado Empleado @relation(fields: [id_empleado], references: [id])
  sucursal Sucursal @relation(fields: [id_sucursal], references: [id])

  @@id([id_empleado, id_sucursal])
}

model Cliente {
  id          Int      @id @default(autoincrement())
  nombre      String   @db.VarChar(100)
  correo      String   @unique @db.VarChar(100)
  telefono    String?  @db.VarChar(15)
  cumpleanios DateTime? 
  
  cupones     CuponAsignado[]
}

model CampaniaGrupo {
  id          Int      @id @default(autoincrement())
  nombre      String   @db.VarChar(100)
  descripcion String?  @db.Text
  excluyente  Boolean  @default(false)

  promociones Promocion[]
}

model Promocion {
  id                Int      @id @default(autoincrement())
  id_campania_grupo Int?
  nombre            String   @db.VarChar(100)
  tipo_descuento    String   @db.VarChar(50)
  valor             Decimal  @db.Decimal(10, 2)
  fecha_fin         DateTime
  descripcion       String?  @db.Text

  campania          CampaniaGrupo? @relation(fields: [id_campania_grupo], references: [id])
  sucursales        PromocionSucursal[]
  cupones_emitidos  CuponAsignado[]
}

model PromocionSucursal {
  id_promocion Int
  id_sucursal   Int

  promocion Promocion @relation(fields: [id_promocion], references: [id])
  sucursal  Sucursal  @relation(fields: [id_sucursal], references: [id])

  @@id([id_promocion, id_sucursal])
}

model CuponAsignado {
  id                Int       @id @default(autoincrement())
  id_cliente        Int
  id_promocion      Int
  id_sucursal_canje Int?
  id_empleado_canje Int?
  
  codigo_unico      String    @unique @db.VarChar(7)
  estado            String    @default("DISPONIBLE")
  fecha_asignacion  DateTime  @default(now())
  fecha_canje       DateTime?

  ip_registro  String?  @db.VarChar(45)

  cliente       Cliente    @relation(fields: [id_cliente], references: [id])
  promocion     Promocion  @relation(fields: [id_promocion], references: [id])
  sucursal      Sucursal?  @relation(fields: [id_sucursal_canje], references: [id])
  empleado      Empleado?  @relation(fields: [id_empleado_canje], references: [id])
}

model DynamicQR {
  id          String    @id @default(uuid())
  slug        String    @unique
  targetUrl   String
  description String?
  visitCount  Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime?  @updatedAt
  visits      QRVisit[]
}

model QRVisit {
  id          Int      @id @default(autoincrement())
  qrId        String
  userAgent   String?  
  ip          String?  
  createdAt   DateTime @default(now())
  
  dynamicQR   DynamicQR @relation(fields: [qrId], references: [id])
}